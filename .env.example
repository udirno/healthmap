# Database connection
DATABASE_URL=postgresql://healthmap_user:healthmap_password@localhost:5432/healthmap_db
POSTGRES_USER=healthmap_user
POSTGRES_PASSWORD=healthmap_password
POSTGRES_DB=healthmap_db

# Redis
REDIS_URL=redis://localhost:6379

# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
